{
  "entities": {
    "GeneratedCode": {
      "title": "Generated Code",
      "description": "A reward code generated by a user.",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "The unique claim code"
        },
        "timestamp": {
          "type": "string",
          "description": "The timestamp string of when the code was generated"
        }
      },
      "required": ["code", "timestamp"]
    }
  },
  "firestore": {
    "codes/{codeId}": {
      "schema": { "$ref": "#/entities/GeneratedCode" },
      "description": "Stores all generated claim codes."
    }
  }
}
